---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { highlightTextParts } from "../lib/highlightText";

const intro =
  "CS (AI/ML) student at Chandigarh University with an 8.1 CGPA, building full-stack web apps, ML models, and tools that solve real problems. Top 50 at Graph-E-Thon 3.0 among 10,000+ teams, open to SWE, ML, and AI Engineer roles.";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hello</div>
    <div class="text-5xl font-bold">I'm Anurag</div>
    <div class="text-3xl py-3 font-bold">Software Engineer / SDE | Product Engineer | Full Stack + ML</div>
    <div class="py-2">
      <text class="text-lg">
        {highlightTextParts(intro).map((part) =>
          part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
        )}
      </text>
    </div>
    <div class="mt-8">
      <a class="btn cursor-target" href="mailto:anuragshakalya@gmail.com" target="_blank">Email</a>
      <a class="btn btn-outline ml-5 cursor-target" href="/Anurag_Resume_Main.pdf" download>Download Resume</a>
      <a href="https://linkedin.com/in/anuraggaur29" target="_blank" class="btn btn-outline ml-5 cursor-target">
        Connect on LinkedIn
      </a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Featured projects {"</>"}</div>
  </div>

  <HorizontalCard
    title="Lecture AI"
    img="/project-images/lecture-capture-project-img.png"
    desc="Built an AI-powered lecture-to-notes web app with React, FastAPI, SQLite, and Python, converting uploaded content into structured searchable notes."
    url="https://lecturecapture-ai.netlify.app/"
    badge="AI"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="News Authenticity Classifier + Telegram Bot"
    img="/project-images/news-classify-project-img.png"
    desc="Trained and benchmarked 3 classifiers using TF-IDF, Naive Bayes, and Logistic Regression, then deployed the best model behind a Telegram bot."
    url="/projects"
    badge="ML"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Web-based Money Tracker"
    img="/project-images/money-tracker-img.png"
    desc="Full-stack finance app with SQL-backed CRUD, multi-category analytics, savings dashboards, and separated frontend, API, and DB layers."
    url="/projects"
    badge="FULL STACK"
  />
</BaseLayout>
