---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
import { highlightTextParts } from "../lib/highlightText";

const profile =
  "CS (AI/ML) student at Chandigarh University, full-stack developer, and problem solver. I build web apps, ML models, and tools that actually solve problems, with hands-on work across MERN, FastAPI, SQL databases, cloud, and generative AI.";

const certifications = [
  "AWS Academy - Generative AI Foundations (Apr 2026)",
  "Microsoft Certified: Azure Fundamentals / AI-900 (Jun 2025)",
  "GitHub Foundations - CI/CD, DevOps, GitHub Actions (Jun 2025 - Jun 2028)",
  "IBM - Generative AI for Data Engineers",
  "Apna College - Full Stack Web Development (MERN)",
  "Google Cloud - Introduction to SQL for BigQuery and Cloud SQL (May 2026)",
  "NVIDIA - Fundamentals of Deep Learning",
  "Duke University - Introduction to Machine Learning (Feb 2025)",
  "Intel India - AI for Entrepreneurship (Mar 2025)",
];

const experiences = [
  {
    title: "Academic Class Representative",
    subtitle: "Jan 2025 to Present | Chandigarh University, AIT-CSE Division",
    description:
      "Represented 60+ students across 3 consecutive semesters, tracked issues, resolved conflicts, and liaised with faculty under competing deadlines.",
  },
  {
    title: "Full Stack Web Development Intern",
    subtitle: "Mar 2026 to Apr 2026 | Webstack Academy - MERN Stack",
    description:
      "Delivered 3+ full-stack features using React.js, Node.js, Express.js, and MongoDB, covering UI, REST APIs, and DB integration within a 2-month sprint cycle.",
  },
  {
    title: "GeeksforGeeks Student Chapter - Chandigarh University",
    subtitle: "Apr 2025 to Feb 2026 | Member",
    description:
      "Contributed to peer learning, programming, and problem-solving initiatives as part of the campus body.",
  },
  {
    title: "Google Developer Student Club, Chandigarh University",
    subtitle: "Mar 2025 to Feb 2026 | Member",
    description: "Collaborated on developer community activities with focus on front-end development, C++, and project building.",
  },
  {
    title: "Graph-E-Thon 3.0 National Hackathon",
    subtitle: "Apr 2026 | Top 50 / 10,000+ teams",
    description:
      "Placed in the top 50 among 10,000+ teams, demonstrating rapid prototyping, teamwork, and problem solving under competition constraints.",
  },
];

const skillGroups = [
  ["C", "C++", "Python", "JavaScript", "SQL", "Rust"],
  ["React.js", "Node.js", "Express.js", "FastAPI", "REST APIs", "HTML/CSS"],
  ["MongoDB", "MySQL", "SQLite", "BigQuery", "Cloud SQL"],
  ["Scikit-learn", "TensorFlow", "NumPy", "Pandas", "NLP", "Prompt Engineering"],
  ["Microsoft Azure", "GCP", "Git", "GitHub", "Postman", "Linux/Unix"],
  ["Data Structures & Algorithms", "OOP", "OS Fundamentals", "SDLC", "Problem Solving"],
];
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5 flex flex-wrap items-center justify-between gap-4">
    <div class="text-3xl w-full font-bold md:w-auto">Profile</div>
    <a class="btn cursor-target" href="/Anurag_Resume_Main.pdf" download>Download Resume</a>
  </div>

  <div class="mb-10 text-justify">
    {highlightTextParts(profile).map((part) =>
      part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
    )}
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="B.E. Computer Science Engineering - AI & ML Specialization"
      subtitle="Aug 2023 to Jan 2027 at Chandigarh University, Mohali, Punjab | CGPA: 8.1"
    />
    <TimeLineElement
      title="Class XII, Non-Medical"
      subtitle="Hari Bhoomi Sr. Sec. School | 84%"
    />
    <TimeLineElement
      title="Class X, ICSE"
      subtitle="Shri Lajja Ram Bashesar Dass Gurukul Vidyapeeth | 88%"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    {experiences.map((experience) => <TimeLineElement {...experience} />)}
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    {certifications.map((certification) => (
      <li>
        {highlightTextParts(certification).map((part) =>
          part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
        )}
      </li>
    ))}
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <div class="mb-10 flex flex-wrap gap-3">
    {skillGroups.flat().map((skill) => (
      <span class="focus-chip">
        {highlightTextParts(skill).map((part) =>
          part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
        )}
      </span>
    ))}
  </div>

  <div class="mb-5 mt-10">
    <div class="text-3xl w-full font-bold">Contact</div>
  </div>

  <ul class="list-disc mx-6">
    <li>Email - anuragshakalya@gmail.com</li>
    <li>Location - Chandigarh, India</li>
    <li>LinkedIn - linkedin.com/in/anuraggaur29</li>
    <li>GitHub - github.com/anuraggaur29</li>
  </ul>
</BaseLayout>
